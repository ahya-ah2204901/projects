{
  "name": "qatari-heritage-explorer",
  "version": "1.0.0",
  "description": "Exploring Qatari History and Heritage - Educational Website",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --no-lint",
    "start": "next start",
    "lint": "next lint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "deploy:pages": "wrangler pages deploy out --project-name qatari-history-and-heritage"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.12.0",
    "next": "^15.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-next": "15.0.3",
    "wrangler": "^4.47.0"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}