# SafeBirth Connect .gitignore

# ===== Java / Maven =====
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.ear
*.log
*.iml

# ===== Spring Boot =====
backend/data/
*.h2.db
*.trace.db
*.lock.db

# ===== Flutter / Dart =====
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/build/
mobile/.pub-cache/
mobile/.pub/
mobile/pubspec.lock

# Generated files
*.g.dart
*.freezed.dart
*.gr.dart
*.mocks.dart

# ===== IDE =====
# IntelliJ IDEA
.idea/
*.iws
*.ipr

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Android Studio
.gradle/
local.properties
*.jks
*.keystore

# ===== macOS =====
.DS_Store
.AppleDouble
.LSOverride
._*

# ===== Windows =====
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ===== Environment =====
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Twilio credentials (never commit!)
twilio.properties

# ===== Logs =====
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===== Testing =====
coverage/
.nyc_output/
test-results/

# ===== Misc =====
*.swp
*.swo
*~
.cache/
.temp/
tmp/
